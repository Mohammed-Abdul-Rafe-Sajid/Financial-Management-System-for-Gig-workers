# session-service environment variables
# Copy to .env for local development

NODE_ENV=development
PORT=3002
SERVICE_NAME=session-service
SERVICE_VERSION=1.0.0

# PostgreSQL — owns: work_sessions table only
DATABASE_URL=postgresql://gigfinance:gigfinance_dev_secret@localhost:5432/gigfinance

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=session-service

# JWT — public key only (session-service never signs tokens)
# Option A: path to PEM file (recommended for local dev)
JWT_PUBLIC_KEY_PATH=../../infra/keys/public.pem
# Option B: PEM string directly (for cloud/CI deployments)
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMII...

# Service-to-service auth (shared with all services, see API_CONTRACT.md §0)
SERVICE_SECRET=dev_service_secret_change_in_prod
