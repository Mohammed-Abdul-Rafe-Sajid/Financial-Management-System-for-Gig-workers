# ── Server ──────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── PostgreSQL ──────────────────────────────────────────────────────────
# user-service owns the `users` table only (CONVENTIONS.md §4)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gigfinance

# ── Redis ───────────────────────────────────────────────────────────────
# Used for: OTP storage (5 min TTL), OTP rate-limit counters, refresh-token
# allow-list (revocation support)
REDIS_URL=redis://localhost:6379

# ── JWT (RS256) ─────────────────────────────────────────────────────────
# PEM keys, with literal "\n" for newlines (standard 12-factor pattern).
# Generate a dev pair with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
JWT_ACCESS_TOKEN_EXPIRY_SECONDS=900
JWT_REFRESH_TOKEN_EXPIRY_SECONDS=604800

# ── OTP ─────────────────────────────────────────────────────────────────
OTP_TTL_SECONDS=300
OTP_RATE_LIMIT_MAX_REQUESTS=5
OTP_RATE_LIMIT_WINDOW_SECONDS=900

# ── Twilio (SMS delivery) ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15005550006

# ── Internal service-to-service auth ───────────────────────────────────
# ⚠️ SPEC GAP: API_CONTRACT.md says GET /api/v1/users/:id "requires service
# auth token, not user JWT" but does not define the mechanism. Implemented
# here as a shared static bearer secret every internal service presents.
# Rotate this independently of user JWT keys.
INTERNAL_SERVICE_TOKEN=change-me-shared-secret
