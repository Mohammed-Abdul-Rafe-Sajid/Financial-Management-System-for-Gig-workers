# =============================================================================
# .env.example — GigFinance AI Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# =============================================================================

# ─── Shared secrets (used by multiple services) ───────────────────────────────

# PostgreSQL password (change in production!)
POSTGRES_PASSWORD=gigfinance_dev_secret

# MongoDB password
MONGO_PASSWORD=gigfinance_dev_secret

# Redis password
REDIS_PASSWORD=gigfinance_dev_secret

# Service-to-service auth token (shared secret for internal API calls)
# Must be the same across all services. Change in production!
SERVICE_SECRET=dev_service_secret_change_in_prod

# ─── JWT Keys ─────────────────────────────────────────────────────────────────
# Generate with: ./infra/scripts/generate_jwt_keys.sh
# The private key path is used only by user-service (for signing).
# The public key path is used by ALL services (for verification).
# In local dev, keys live in ./infra/keys/
JWT_PRIVATE_KEY_PATH=./infra/keys/private.pem
JWT_PUBLIC_KEY_PATH=./infra/keys/public.pem

# Alternatively, pass keys as env vars directly (for cloud deployment)
# JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...

# ─── External API Keys ────────────────────────────────────────────────────────

# Twilio (OTP delivery via SMS) — user-service
# Sign up at https://www.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# OpenWeatherMap (weather enrichment) — enrichment-service
# Sign up at https://openweathermap.org/api (free tier: 1000 calls/day)
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key

# Google Maps Platform (geocoding + distance) — enrichment-service
# Enable: Geocoding API, Places API, Distance Matrix API
# https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Anthropic API (chatbot LLM) — chatbot-service
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Pinecone (vector DB for RAG) — chatbot-service
# Sign up at https://www.pinecone.io (free tier available)
PINECONE_API_KEY=your_pinecone_api_key
# The index name is fixed: gigfinance-knowledge-base (see DB_SCHEMA.sql)
# Create it in Pinecone console: dimension=384, metric=cosine

# ─── Service-specific overrides (optional — defaults shown) ───────────────────

# user-service (port 3001)
# OTP_EXPIRY_SECONDS=300
# OTP_MAX_ATTEMPTS=5
# OTP_WINDOW_SECONDS=900
# JWT_ACCESS_EXPIRY_SECONDS=900
# JWT_REFRESH_EXPIRY_SECONDS=604800

# session-service (port 3002)
# (no additional vars beyond shared ones)

# enrichment-service (port 3003, health only)
# MAX_CONCURRENT_ENRICHMENTS=20

# prediction-service (port 8001)
# MODEL_GENERIC_PATH=./models/generic_model.joblib
# MODEL_VERSION=1.0.0

# iss-service (port 8002)
# (no additional vars beyond shared ones)

# expense-service (port 3004)
# (no additional vars beyond shared ones)

# chatbot-service (port 8003)
# PINECONE_INDEX_NAME=gigfinance-knowledge-base

# analytics-service (port 8004)
# ANALYTICS_CACHE_TTL_SECONDS=300

# api-gateway (port 3000)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100
# CORS_ALLOWED_ORIGINS=http://localhost:3100,http://localhost:3000

# web frontend (port 3100)
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GigFinance AI
